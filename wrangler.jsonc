{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "poke-app",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
